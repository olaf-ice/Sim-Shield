# ── Server ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────────────
# Local MongoDB (default):
MONGODB_URI=mongodb://localhost:27017/simshield

# OR MongoDB Atlas (cloud — replace with your own connection string):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/simshield

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=simshield_super_secret_jwt_key_CHANGE_IN_PRODUCTION_2026
JWT_EXPIRES_IN=30d

# ── CORS ────────────────────────────────────────────────────────
# URL of your frontend (used for CORS whitelist)
FRONTEND_URL=http://127.0.0.1:5500
